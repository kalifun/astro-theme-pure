---
interface Props {
  width?: string
}

const { width } = Astro.props
---

<div class='mdx-repl liquid-glass overflow-hidden rounded-xl'>
  <div class='mdx-repl-container flex flex-col items-center justify-center p-4'>
    <slot />
  </div>
  <div class='mdx-repl-desc border-t border-[hsl(var(--foreground)/0.08)] bg-[hsl(var(--muted)/0.72)] backdrop-blur-lg dark:border-[hsl(0_0%_100%/0.1)] dark:bg-[hsl(var(--muted)/0.5)]'>
    <slot name='desc' />
  </div>
</div>

<style define:vars={{ width }}>
  .mdx-repl {
    background: linear-gradient(
      135deg,
      hsl(var(--primary) / 0.14) 0%,
      hsl(var(--background) / 0.38) 52%,
      hsl(var(--foreground) / 0.04) 100%
    );
  }

  /* Container */
  .mdx-repl-container > :global(*) {
    width: var(--width);
  }
  .mdx-repl-container > :global(*):first-child {
    margin-top: 0;
  }
  .mdx-repl-container > :global(*):last-child {
    margin-bottom: 0;
  }

  /* Desc especial adaption */
  /* Code */
  .mdx-repl :global(.astro-code) {
    margin: 0;
    border-radius: 0;
  }
  /* Tabs */
  .mdx-repl :global(div[role='tabpanel']) {
    margin-top: 0;
  }
</style>
