---
import { type ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

import { Svg } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'

interface Props {
  class?: string
  title: string
  tools: {
    name: string
    description: string
    href: string
    icon: Promise<typeof import('*.svg?raw')> | ImageMetadata
    darkIcon?: Promise<typeof import('*.svg?raw')> | ImageMetadata
  }[]
}

const { class: className, title, tools, ...props } = Astro.props

function isImageMetadata(obj: unknown): obj is ImageMetadata {
  return typeof obj === 'object' && obj !== null && 'src' in obj
}
---

<div
  class={cn(
    'not-prose liquid-glass flex flex-col rounded-xl py-3 px-3 gap-y-3 sm:gap-y-4',
    className
  )}
  {...props}
>
  <div class='m-0 px-2 text-lg font-medium'>{title}</div>
  <div class='grid grid-cols-1 gap-x-2 gap-y-2 sm:grid-cols-2'>
    {
      tools.map((tool) => (
        <a
          class='group relative text-sm leading-normal no-underline'
          href={tool.href}
          id={tool.name}
          target='_blank'
        >
          <div class='flex items-center gap-x-3 rounded-lg border border-[hsl(var(--foreground)/0.08)] bg-[hsl(var(--foreground)/0.05)] px-1.5 py-1 backdrop-blur-md transition-colors hover:border-[hsl(var(--foreground)/0.14)] hover:bg-[hsl(var(--foreground)/0.09)] dark:border-[hsl(0_0%_100%/0.1)] dark:bg-[hsl(0_0%_100%/0.06)] dark:hover:border-[hsl(0_0%_100%/0.16)] dark:hover:bg-[hsl(0_0%_100%/0.1)]'>
            {tool.darkIcon ? (
              <>
                {isImageMetadata(tool.icon) ? (
                  <div class='size-10 rounded-lg bg-[hsl(var(--foreground)/0.06)] p-2 backdrop-blur-sm dark:bg-[hsl(0_0%_100%/0.08)] dark:hidden'>
                    <Image src={tool.icon} alt={tool.name} class='h-full w-full object-contain' />
                  </div>
                ) : (
                  <Svg
                    src={tool.icon}
                    class='size-10 rounded-lg bg-[hsl(var(--foreground)/0.06)] fill-foreground p-2 backdrop-blur-sm dark:bg-[hsl(0_0%_100%/0.08)] dark:hidden'
                  />
                )}

                {isImageMetadata(tool.darkIcon) ? (
                  <div class='size-10 rounded-lg bg-[hsl(var(--foreground)/0.06)] p-2 backdrop-blur-sm hidden dark:bg-[hsl(0_0%_100%/0.08)] dark:block'>
                    <Image
                      src={tool.darkIcon}
                      alt={tool.name}
                      class='h-full w-full object-contain'
                    />
                  </div>
                ) : (
                  <Svg
                    src={tool.darkIcon}
                    class='size-10 rounded-lg bg-[hsl(var(--foreground)/0.06)] fill-foreground p-2 backdrop-blur-sm hidden dark:bg-[hsl(0_0%_100%/0.08)] dark:block'
                  />
                )}
              </>
            ) : (
              <>
                {isImageMetadata(tool.icon) ? (
                  <div class='size-10 rounded-lg bg-[hsl(var(--foreground)/0.06)] p-2 backdrop-blur-sm dark:bg-[hsl(0_0%_100%/0.08)]'>
                    <Image src={tool.icon} alt={tool.name} class='h-full w-full object-contain' />
                  </div>
                ) : (
                  <Svg
                    src={tool.icon}
                    class='size-10 rounded-lg bg-[hsl(var(--foreground)/0.06)] fill-foreground p-2 backdrop-blur-sm dark:bg-[hsl(0_0%_100%/0.08)]'
                  />
                )}
              </>
            )}
            <div class='z-20 flex flex-col'>
              <div class='font-medium text-foreground'>{tool.name}</div>
              <div class='font-normal'>{tool.description}</div>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>
