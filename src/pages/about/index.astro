---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import {
  aboutPageData,
  aboutSectionMeta,
  buildAboutHeadings,
  type AboutBlogSection,
  type AboutGossipsSection,
  type AboutSocialSection
} from '@/data/about'

const d = aboutPageData
const s = aboutSectionMeta
const socialBlock = d.social as AboutSocialSection
const gossipsBlock = d.gossips as AboutGossipsSection
const blogBlock = d.blog as AboutBlogSection
const visibleSocial = socialBlock.enabled !== false
const visibleGossips = gossipsBlock.enabled !== false
const visibleBlog = blogBlock.enabled !== false
const headings = buildAboutHeadings(d)
---

<PageLayout title={d.pageTitle} {headings} comment>
  <p>{d.intro.role}</p>
  {d.intro.paragraphs.map((p) => <p>{p}</p>)}
  <p>
    {d.intro.mottoPrefix}
    <Spoiler>{d.intro.mottoSpoiler}</Spoiler>
  </p>
  <Button
    title={d.sponsorButton.title}
    class='w-fit'
    href={d.sponsorButton.href}
    variant={d.sponsorButton.variant}
  />

  <h2 id={s.hobbies.slug}>{s.hobbies.text}</h2>
  <ul>
    {d.hobbies.items.map((item) => <li>{item}</li>)}
  </ul>

  <h2 id={s.tools.slug}>{s.tools.text}</h2>
  <p>{d.tools.intro}</p>
  {
    d.tools.sections.map((section) => (
      <ToolSection class='mb-5' title={section.title} tools={section.tools} />
    ))
  }

  {
    visibleSocial && (
      <>
        <h2 id={s.social.slug}>{s.social.text}</h2>
        <p>{d.social.intro}</p>
        <Substats stats={d.social.stats} />
      </>
    )
  }

  {
    visibleGossips && (
      <>
        <h2 id={s.gossips.slug}>{s.gossips.text}</h2>
        <Collapse title={d.gossips.collapseTitle}>
          <Fragment set:html={d.gossips.bodyHtml} />
        </Collapse>
      </>
    )
  }

  {
    visibleBlog && (
      <>
        <h2 id={s.blog.slug}>{s.blog.text}</h2>
        <p>{d.blog.timelineIntro}</p>
        <Timeline events={d.blog.events} />
        <p>{d.blog.creditsIntro}</p>
        <ul set:html={d.blog.creditLines.join('')} />
      </>
    )
  }
</PageLayout>
