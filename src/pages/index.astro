---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import { aboutPageData } from '@/data/about'
import { homePageData } from '@/data/home'
import config from '@/site-config'

const about = aboutPageData
const h = homePageData

const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, h.posts.maxPosts)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )

const quoteEnabled = config.integ.quote?.enable !== false
---

<PageLayout meta={{ title: h.pageMetaTitle }} highlightColor={h.highlightColor}>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          {
            h.heroLabels.map((label) =>
              label.kind === 'link' ? (
                <Label
                  title={label.title}
                  as='a'
                  href={label.href}
                  target={label.target ?? '_blank'}
                >
                  <Icon name={label.icon} class='size-5' slot='icon' />
                </Label>
              ) : (
                <Label title={label.title}>
                  <Icon name={label.icon} class='size-5' slot='icon' />
                </Label>
              )
            )
          }
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title={about.homePreview.sectionTitle}>
        <p class='text-muted-foreground'>{about.intro.role}</p>
        {about.intro.paragraphs.map((p) => <p class='text-muted-foreground'>{p}</p>)}
        <Button
          title={about.homePreview.moreButton.title}
          class='w-fit self-end'
          href={about.homePreview.moreButton.href}
          variant={about.homePreview.moreButton.variant}
        />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title={h.posts.sectionTitle}>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button
              title={h.posts.moreButton.title}
              class='w-fit self-end'
              href={h.posts.moreButton.href}
              variant={h.posts.moreButton.variant}
            />
          </Section>
        )
      }

      {
        h.education.enabled !== false && (
          <Section title={h.education.sectionTitle}>
            {h.education.cards.map((card) => (
              <Card
                as={card.as}
                heading={card.heading}
                subheading={card.subheading}
                date={card.date}
                href={card.href}
              />
            ))}
          </Section>
        )
      }

      {
        h.websiteList.enabled !== false && (
          <Section title={h.websiteList.sectionTitle}>
            <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
              {h.websiteList.items.map((item) => (
                <ProjectCard
                  href={item.href}
                  heading={item.heading}
                  subheading={item.subheading}
                  imagePath={item.imagePath}
                />
              ))}
            </div>
          </Section>
        )
      }

      {
        h.certifications.enabled !== false && (
          <Section title={h.certifications.sectionTitle}>
            <Card
              as={h.certifications.card.as}
              heading={h.certifications.card.heading}
              subheading={h.certifications.card.subheading}
              date={h.certifications.card.date}
              href={h.certifications.card.href}
            />
          </Section>
        )
      }

      {
        h.skills.enabled !== false && (
          <Section title={h.skills.sectionTitle}>
            {h.skills.groups.map((g) => (
              <SkillLayout title={g.title} skills={g.skills} />
            ))}
          </Section>
        )
      }
    </div>
    {quoteEnabled && <Quote class='mt-12' />}
  </main>
</PageLayout>
