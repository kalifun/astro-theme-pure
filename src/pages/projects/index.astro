---
import { Image } from 'astro:assets'

import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import Sponsors from '@/components/projects/Sponsors.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import KeyIcon from '@/assets/icons/key.svg'
import {
  buildProjectsHeadings,
  projectsPageData,
  type ProjectsContentSection,
  type ProjectsGpgSection,
  type ProjectsHeroSection,
  type ProjectsProgramsSection,
  type ProjectsSponsorshipSection
} from '@/data/projects'

const d = projectsPageData

const heroBlock = d.hero as ProjectsHeroSection
const visibleHero = heroBlock.enabled !== false

const programsSec = d.sections.programs as ProjectsProgramsSection
const learningsSec = d.sections.learnings as ProjectsContentSection
const othersSec = d.sections.others as ProjectsContentSection

const programsMain = programsSec.projects
const programsArchived = programsSec.archived.projects
const learnings = learningsSec.projects
const others = othersSec.projects

const gpgBlock = d.gpg as ProjectsGpgSection
/** Hide entire GPG block (incl. TOC entry) when `gpg.enabled === false`. Omit = show. */
const visibleGpg = gpgBlock.enabled !== false

const sponsorshipBlock = d.sponsorship as ProjectsSponsorshipSection
/** Hide entire sponsorship block (incl. TOC entry) when `sponsorship.enabled === false`. Omit = show. */
const visibleSponsorship = sponsorshipBlock.enabled !== false

const sponsorshipMethods = visibleSponsorship ? sponsorshipBlock.methods : []
const sponsors = visibleSponsorship ? sponsorshipBlock.sponsors : []

const visiblePrograms =
  programsSec.enabled !== false && (programsMain.length > 0 || programsArchived.length > 0)
const visibleLearnings = learningsSec.enabled !== false && learnings.length > 0
const visibleOthers = othersSec.enabled !== false && others.length > 0

const headings = buildProjectsHeadings(d, {
  programs: visiblePrograms,
  learnings: visibleLearnings,
  others: visibleOthers,
  gpg: visibleGpg,
  sponsorship: visibleSponsorship
})
---

<PageLayout title={d.pageTitle} {headings}>
  {
    visibleHero && (
      <div class='not-prose flex justify-center'>
        <a
          href={heroBlock.href}
          target='_blank'
          class='flex items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'
        >
          <span class='size-2 rounded-full bg-green-400'></span>
          <p class='font-medium text-muted-foreground'>{heroBlock.label}</p>
        </a>
      </div>
    )
  }
  <p>{d.intro.githubActivitiesLabel}</p>
  <p>
    <Image
      src={d.githubChart.imageUrl}
      alt={d.githubChart.imageAlt}
      inferSize
      loading='lazy'
    />
  </p>
  <p>{d.intro.bodyHtml}</p>
  {
    visibleSponsorship && (
      <Button title={d.intro.sponsorshipCta.title} class='w-fit' href={d.intro.sponsorshipCta.href}>
        <Icon class='size-5' name='receive-money' slot='before' />
      </Button>
    )
  }

  {
    visiblePrograms && (
      <>
        <h2 id='programs'>{programsSec.title}</h2>
        {programsMain.length > 0 && <ProjectSection projects={programsMain} />}
        {programsArchived.length > 0 && (
          <Collapse title={programsSec.archived.collapseTitle}>
            <ProjectSection projects={programsArchived} />
          </Collapse>
        )}
      </>
    )
  }

  {
    visibleLearnings && (
      <>
        <h2 id='learnings'>{learningsSec.title}</h2>
        <ProjectSection class='my-2' projects={learnings} />
      </>
    )
  }

  {
    visibleOthers && (
      <>
        <h2 id='others'>{othersSec.title}</h2>
        <ProjectSection projects={others} />
      </>
    )
  }

  {
    visibleGpg && (
      <>
        <h2 id='gpg-signature'>{gpgBlock.title}</h2>
        <p>
          {gpgBlock.descriptionBeforeKey}
          <code>{gpgBlock.keyDisplay}</code>
          {gpgBlock.descriptionAfterKey}
        </p>
        <Button href={gpgBlock.keyButtonHref} title={gpgBlock.keyButtonTitle} target='_blank'>
          <KeyIcon class='size-5' slot='before' />
        </Button>
      </>
    )
  }

  {
    visibleSponsorship && (
      <>
        <h2 id='sponsorship'>{d.sponsorship.title}</h2>
        <p set:html={d.sponsorship.chineseMethodsHtml} />
        {sponsorshipMethods.length > 0 && <Sponsorship methods={sponsorshipMethods} />}
        <p set:html={d.sponsorship.globalMethodsHtml} />
        <p>
          {d.sponsorship.emailNoteBefore}
          <code
            style='cursor: pointer'
            onclick='const m=atob(this.textContent);alert(m);window.open(`mailto:${m}`,"_blank")'
            >{d.sponsorship.emailBase64}</code
          >
          {d.sponsorship.emailNoteAfter}
        </p>
        {sponsors.length > 0 && (
          <>
            <p>{d.sponsorship.sponsorsIntro}</p>
            <Sponsors progressMax={d.sponsorship.sponsorsProgressMax} sponsors={sponsors} />
          </>
        )}
      </>
    )
  }
</PageLayout>

<style>
  .sponsorship-card {
    & .sponsorship-card-img {
      opacity: 0.3;
      --un-blur: blur(4px);
      filter: var(--un-blur);
    }

    &:hover {
      & .sponsorship-card-icon {
        opacity: 0;
      }
      & .sponsorship-card-img {
        opacity: 1;
        --un-blur: blur(0);
      }
    }
  }
</style>
